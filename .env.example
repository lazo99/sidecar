# Sidecar Configuration
PORT=8000
LOG_LEVEL=INFO

# Bitwarden Secrets Manager (required)
# Get token from: https://vault.bitwarden.com/sm/
# Must have a secret named "jwt-secret" in your Bitwarden SM project
BITWARDEN_SM_TOKEN=your-bitwarden-access-token

# Optional: JWT_SECRET_KEY fallback (for local development without Bitwarden)
# If not using Bitwarden, set this and bws is not required
# JWT_SECRET_KEY=your-secret-key-here-min-32-chars

# Optional: GCP configuration for Cloud Run deployment
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1
