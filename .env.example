# Sidecar Configuration
PORT=8000
LOG_LEVEL=INFO

# JWT Configuration (required)
JWT_SECRET_KEY=your-secret-key-here-min-32-chars

# API Keys (set as needed for each API)
# Format: API_KEY_{API_NAME}={key}
# Example:
# API_KEY_CLAUDE=sk-ant-...
# API_KEY_OPENAI=sk-...
# API_KEY_GCP={...json service account...}

# Optional: GCP configuration for Cloud Run deployment
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1
